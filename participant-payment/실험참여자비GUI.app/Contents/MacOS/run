#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
#  실험참여자비GUI.app  —  macOS .app launcher  v2.0
#  이 .app을 Excel 템플릿 파일들이 있는 폴더에 넣고 더블클릭하세요.
# ─────────────────────────────────────────────────────────────────────────────

SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RESOURCES="$SCRIPT_PATH/../Resources"
TEMPLATES_DIR="$(cd "$SCRIPT_PATH/../../.." && pwd)"
export LAB_CHORE_DIR="$TEMPLATES_DIR"

# Python 탐색 (pyenv > brew arm > brew intel > system)
PYTHON=""
for py in \
    "$HOME/.pyenv/shims/python3" \
    "/opt/homebrew/bin/python3" \
    "/usr/local/bin/python3" \
    "/usr/bin/python3" \
    "python3"; do
    if "$py" --version &>/dev/null 2>&1; then PYTHON="$py"; break; fi
done

if [ -z "$PYTHON" ]; then
    osascript -e 'display alert "Python 3를 찾을 수 없습니다." message "터미널에서:\n  brew install python\n실행 후 재시작하세요." as critical'
    exit 1
fi

# 패키지 설치 확인 (최초 1회)
MISSING=""
for pkg in streamlit openpyxl PIL streamlit_drawable_canvas; do
    "$PYTHON" -c "import $pkg" &>/dev/null 2>&1 || MISSING="$MISSING $pkg"
done

if [ -n "$MISSING" ]; then
    osascript -e 'display dialog "필요한 패키지를 설치합니다 (최초 1회, 약 1분).\n\n확인을 누르면 시작합니다." buttons {"취소","확인"} default button "확인"' 2>/dev/null
    [ $? -ne 0 ] && exit 0
    "$PYTHON" -m pip install streamlit openpyxl "streamlit-drawable-canvas" Pillow \
        --quiet --break-system-packages 2>/dev/null \
        || "$PYTHON" -m pip install streamlit openpyxl "streamlit-drawable-canvas" Pillow --quiet
fi

# 포트 정리 후 실행
PORT=8501
lsof -ti tcp:$PORT | xargs kill -9 2>/dev/null

cd "$TEMPLATES_DIR"
"$PYTHON" -m streamlit run \
    "$RESOURCES/app.py" \
    --server.port $PORT \
    --server.headless false \
    --browser.gatherUsageStats false
